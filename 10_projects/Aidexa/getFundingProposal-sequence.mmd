sequenceDiagram
    participant Caller
    participant Service as FundingProposalServiceV2
    participant BPM    as BpmAdapter
    participant Adapter as ActicoAdapter
    participant Actico

    Caller  ->> Service  : getFundingProposal(bpmId)

    Service ->> BPM      : getStartConfigFlags(bpmId)
    BPM     -->> Service : isDifferentiatedInquiryFeeEnabled: true

    Note over Service : [DECISIONE]
    Note over Service : discounted == original
    Note over Service : → fee = null

    Service ->> Adapter  : buildPricingSustainabilityRequest(fee = null)
    Adapter ->> Actico   : POST /pricing (creditApplicationFeePercentage: absent)
    Actico  -->> Adapter : response
    Adapter -->> Service : PricingSustainabilityResponse

    Service -->> Caller  : FundingProposalResponse
